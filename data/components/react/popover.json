{
  "name": "Popover",
  "framework": "react",
  "frameworkName": "React",
  "category": "overlay",
  "description": "",
  "props": [
    {
      "name": "content",
      "type": "ReactNode",
      "required": true,
      "description": "Popover content"
    },
    {
      "name": "header",
      "type": "ReactNode",
      "required": false,
      "description": "Popover header (optional)"
    },
    {
      "name": "footer",
      "type": "ReactNode",
      "required": false,
      "description": "Popover footer (optional)"
    },
    {
      "name": "children",
      "type": "ReactNode",
      "required": true,
      "description": "Element that triggers the popover"
    },
    {
      "name": "placement",
      "type": "PopoverPlacement",
      "required": false,
      "default": "'bottom'",
      "description": "Popover placement"
    },
    {
      "name": "trigger",
      "type": "PopoverTrigger",
      "required": false,
      "default": "'click'",
      "description": "Trigger type"
    },
    {
      "name": "showArrow",
      "type": "boolean",
      "required": false,
      "default": "true",
      "description": "Show arrow"
    },
    {
      "name": "showCloseButton",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Show close button"
    },
    {
      "name": "closeOnOutsideClick",
      "type": "boolean",
      "required": false,
      "default": "true",
      "description": "Close on outside click"
    },
    {
      "name": "closeOnEscape",
      "type": "boolean",
      "required": false,
      "default": "true",
      "description": "Close on escape key"
    },
    {
      "name": "delay",
      "type": "number",
      "required": false,
      "default": "200",
      "description": "Delay before showing (ms) - for hover trigger"
    },
    {
      "name": "isOpen",
      "type": "boolean",
      "required": false,
      "description": "Controlled open state"
    },
    {
      "name": "defaultOpen",
      "type": "boolean",
      "required": false,
      "description": "Default open state"
    },
    {
      "name": "onOpenChange",
      "type": "(isOpen: boolean) => void",
      "required": false,
      "description": "Callback when open state changes"
    },
    {
      "name": "disabled",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Disable popover"
    },
    {
      "name": "className",
      "type": "string",
      "required": false,
      "description": "Additional CSS classes"
    },
    {
      "name": "style",
      "type": "PopoverCSSVariables",
      "required": false,
      "description": "Inline styles with CSS variable support"
    },
    {
      "name": "ariaLabel",
      "type": "string",
      "required": false,
      "description": "Accessible label"
    }
  ],
  "version": "0.2.1",
  "relatedComponents": [
    "Modal",
    "Drawer",
    "Tooltip",
    "Dropdown"
  ],
