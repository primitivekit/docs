{
  "name": "Typography",
  "framework": "react",
  "frameworkName": "React",
  "category": "data-display",
  "description": "",
  "props": [
    {
      "name": "children",
      "type": "ReactNode",
      "required": true,
      "description": "Content"
    },
    {
      "name": "variant",
      "type": "TypographyVariant",
      "required": false,
      "default": "'body1'",
      "description": "Typography variant"
    },
    {
      "name": "weight",
      "type": "TypographyWeight",
      "required": false,
      "description": "Font weight"
    },
    {
      "name": "align",
      "type": "TypographyAlign",
      "required": false,
      "description": "Text alignment"
    },
    {
      "name": "color",
      "type": "string",
      "required": false,
      "description": "Text color"
    },
    {
      "name": "ellipsis",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Truncate text with ellipsis"
    },
    {
      "name": "lineClamp",
      "type": "number",
      "required": false,
      "description": "Number of lines before truncating (requires ellipsis)"
    },
    {
      "name": "component",
      "type": "'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6' | 'p' | 'span' | 'div'",
      "required": false,
      "description": "Render as specific HTML element"
    },
    {
      "name": "className",
      "type": "string",
      "required": false,
      "description": "Additional CSS classes"
    },
    {
      "name": "style",
      "type": "TypographyCSSVariables",
      "required": false,
      "description": "Inline styles with CSS variable support"
    }
  ],
  "version": "0.2.1",
  "relatedComponents": [
    "Avatar",
    "Tag",
