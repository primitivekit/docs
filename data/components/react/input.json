{
  "name": "Input",
  "framework": "react",
  "frameworkName": "React",
  "category": "form",
  "description": "",
  "props": [
    {
      "name": "size",
      "type": "InputSize",
      "required": false,
      "default": "'medium'",
      "description": "Input size"
    },
    {
      "name": "variant",
      "type": "InputVariant",
      "required": false,
      "default": "'default'",
      "description": "Visual style variant"
    },
    {
      "name": "state",
      "type": "InputState",
      "required": false,
      "default": "'default'",
      "description": "Input state for validation feedback"
    },
    {
      "name": "label",
      "type": "string",
      "required": false,
      "description": "Label text"
    },
    {
      "name": "helperText",
      "type": "string",
      "required": false,
      "description": "Helper text displayed below input"
    },
    {
      "name": "error",
      "type": "string",
      "required": false,
      "description": "Error message (sets state to 'error')"
    },
    {
      "name": "success",
      "type": "string",
      "required": false,
      "description": "Success message (sets state to 'success')"
    },
    {
      "name": "warning",
      "type": "string",
      "required": false,
      "description": "Warning message (sets state to 'warning')"
    },
    {
      "name": "fullWidth",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Make input full width"
    },
    {
      "name": "leftElement",
      "type": "ReactNode",
      "required": false,
      "description": "Icon or element to display on the left"
    },
    {
      "name": "rightElement",
      "type": "ReactNode",
      "required": false,
      "description": "Icon or element to display on the right"
    },
    {
      "name": "className",
      "type": "string",
      "required": false,
      "description": "Additional CSS classes"
    },
    {
      "name": "style",
      "type": "InputCSSVariables",
      "required": false,
      "description": "Inline styles with CSS variable support"
    },
    {
      "name": "id",
      "type": "string",
      "required": false,
      "description": "ID for the input element"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Name attribute"
    },
    {
      "name": "type",
      "type": "'text' | 'email' | 'password' | 'number' | 'tel' | 'url' | 'search' | 'date' | 'time' | 'datetime-local' | 'month' | 'week'",
      "required": false,
      "default": "'text'",
      "description": "Input type"
    },
    {
      "name": "placeholder",
      "type": "string",
      "required": false,
      "description": "Placeholder text"
    },
    {
      "name": "value",
      "type": "string | number",
      "required": false,
      "description": "Input value (controlled)"
    },
    {
      "name": "defaultValue",
      "type": "string | number",
      "required": false,
      "description": "Default value (uncontrolled)"
    },
    {
      "name": "onChange",
      "type": "(event: React.ChangeEvent<HTMLInputElement>) => void",
      "required": false,
      "description": "Change handler"
    },
    {
      "name": "onFocus",
      "type": "(event: React.FocusEvent<HTMLInputElement>) => void",
      "required": false,
      "description": "Focus handler"
    },
    {
      "name": "onBlur",
      "type": "(event: React.FocusEvent<HTMLInputElement>) => void",
      "required": false,
      "description": "Blur handler"
    },
    {
      "name": "disabled",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Disable the input"
    },
    {
      "name": "readOnly",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Make input read-only"
    },
    {
      "name": "required",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Require input"
    },
    {
      "name": "ariaLabel",
      "type": "string",
      "required": false,
      "description": "Accessible label (if label prop not used)"
    },
    {
      "name": "ariaDescribedBy",
      "type": "string",
      "required": false,
      "description": "ID of element that describes the input"
    },
    {
      "name": "ariaInvalid",
      "type": "boolean",
      "required": false,
      "description": "Indicates invalid input"
    }
  ],
  "version": "0.2.1",
  "relatedComponents": [
    "Button",
    "Select",
    "Checkbox",
    "Radio",
    "Switch"
  ],
