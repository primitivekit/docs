{
  "name": "Textarea",
  "framework": "react",
  "frameworkName": "React",
  "category": "form",
  "description": "",
  "props": [
    {
      "name": "size",
      "type": "TextareaSize",
      "required": false,
      "default": "'medium'",
      "description": "Textarea size"
    },
    {
      "name": "variant",
      "type": "TextareaVariant",
      "required": false,
      "default": "'default'",
