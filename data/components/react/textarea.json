    },
    {
      "name": "ariaDescribedBy",
      "type": "string",
      "required": false,
      "description": "ID of element that describes the textarea"
    },
    {
      "name": "ariaInvalid",
      "type": "boolean",
      "required": false,
      "description": "Indicates invalid textarea"
    }
