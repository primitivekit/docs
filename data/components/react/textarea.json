    {
      "name": "readOnly",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Make textarea read-only"
    },
    {
      "name": "required",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Require textarea"
    },
    {
      "name": "maxLength",
      "type": "number",
      "required": false,
