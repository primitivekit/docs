{
  "name": "Link",
  "framework": "react",
  "frameworkName": "React",
  "category": "navigation",
  "description": "",
  "props": [
    {
      "name": "children",
      "type": "ReactNode",
      "required": false,
      "description": "Link content"
    },
    {
      "name": "variant",
      "type": "LinkVariant",
      "required": false,
      "default": "'default'",
      "description": "Visual style variant"
    },
    {
      "name": "size",
      "type": "LinkSize",
      "required": false,
      "default": "'medium'",
      "description": "Link size"
    },
    {
      "name": "disabled",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Disable the link"
    },
    {
      "name": "external",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Show external link icon"
    },
    {
      "name": "underline",
      "type": "'none' | 'hover' | 'always'",
      "required": false,
      "default": "'hover'",
      "description": "Underline style"
    },
    {
      "name": "href",
      "type": "string",
      "required": false,
      "description": "URL to navigate to"
    },
    {
      "name": "target",
      "type": "string",
      "required": false,
      "description": "Target attribute"
    },
    {
      "name": "rel",
      "type": "string",
      "required": false,
      "description": "Rel attribute"
    },
    {
      "name": "className",
      "type": "string",
      "required": false,
      "description": "Additional CSS classes"
    },
    {
      "name": "style",
      "type": "LinkCSSVariables",
      "required": false,
      "description": "Inline styles with CSS variable support"
    },
    {
      "name": "leftIcon",
      "type": "ReactNode",
      "required": false,
      "description": "Icon on the left side"
    },
    {
      "name": "rightIcon",
      "type": "ReactNode",
      "required": false,
      "description": "Icon on the right side"
    },
    {
      "name": "ariaLabel",
      "type": "string",
      "required": false,
      "description": "Accessible label"
    },
    {
      "name": "ariaDescribedBy",
      "type": "string",
      "required": false,
      "description": "ID of element that describes the link"
    },
    {
      "name": "ariaCurrent",
      "type": "'page' | 'step' | 'location' | 'date' | 'time' | 'true' | 'false'",
      "required": false,
      "description": "Indicates current page"
    }
  ],
  "version": "0.2.1",
  "relatedComponents": [
