{
  "name": "Tabs",
  "framework": "react",
  "frameworkName": "React",
  "category": "navigation",
  "description": "",
  "props": [
    {
      "name": "items",
      "type": "TabItem[]",
      "required": true,
      "description": "Array of tab items"
    },
    {
      "name": "activeTab",
      "type": "string",
      "required": false,
      "description": "Currently active tab ID"
    },
    {
      "name": "defaultActiveTab",
      "type": "string",
      "required": false,
      "description": "Default active tab ID"
    },
    {
      "name": "onChange",
      "type": "(tabId: string) => void",
      "required": false,
      "description": "Callback when tab changes"
    },
    {
      "name": "variant",
      "type": "TabsVariant",
      "required": false,
      "default": "'line'",
      "description": "Visual style variant"
    },
    {
      "name": "size",
      "type": "TabsSize",
      "required": false,
      "default": "'medium'",
      "description": "Tab size"
    },
    {
      "name": "orientation",
      "type": "TabsOrientation",
      "required": false,
      "default": "'horizontal'",
      "description": "Tab orientation"
    },
    {
      "name": "fullWidth",
      "type": "boolean",
      "required": false,
      "default": "false",
      "description": "Make tabs full width"
    },
    {
      "name": "className",
      "type": "string",
      "required": false,
      "description": "Additional CSS classes"
    },
    {
      "name": "style",
      "type": "TabsCSSVariables",
      "required": false,
      "description": "Inline styles with CSS variable support"
    },
    {
      "name": "ariaLabel",
      "type": "string",
      "required": false,
      "description": "Accessible label for tab list"
    }
  ],
  "version": "0.2.1",
  "relatedComponents": [
